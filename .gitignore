*.log
logs/
.wake.lock
.lock
tmp/
*.tmp
*.pid

# OS cruft
.DS_Store
Thumbs.db
._*

# Editor
.vscode/
.idea/
*.swp
*.swo
*~

# Backups from our work
*.backup
*.bak
dist-backup-*/
trial-*/
bus-audit-*/

